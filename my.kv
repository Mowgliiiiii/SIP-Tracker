ScreenManager:
    Screen:
        name: 'Main'

        BoxLayout:
            padding: [12,15,12,6]
            orientation: 'vertical'

            ScrollView:
                size_hint: (1,1)
                
                GridLayout:
                    id: fund_list
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: 5

                    Label:
                        text: 'Dashboard'
                        size_hint_y: None
                        height: 150
                    
                    
    Screen:
        name: 'fund_detail'

        BoxLayout:
            orientation: 'vertical'
            padding: [12,15,12,6]

            BoxLayout:
                size_hint_y: None
                height: 25

                Button:
                    text: 'Back'
                    on_release: app.root.current = "Main"
                    size_hint_x: 0.2

                Widget:

            ScrollView:
                size_hint: (1,1)

                GridLayout:
                    id: instalment_list
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: 5

                    Label:
                        text: 'Dashboard'
                        size_hint_y: None
                        height: 150
                    
                
        



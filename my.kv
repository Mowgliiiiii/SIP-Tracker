ScreenManager:
    Screen:
        name: 'Main'

        BoxLayout:
            padding: [12,15,12,6]
            orientation: 'vertical'

            ScrollView:
                size_hint: (1,1)
                
                GridLayout:
                    id: fund_list
                    size_hint: (1,0.65)
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: 5

                    Label:
                        text: 'Dashboard'
                        size_hint_y: None
                        height: 120
                    
                    
    Screen:
        name: 'fund_detail'

        BoxLayout:
            orientation: 'vertical'
            padding: [12,15,12,6]

            Label:
                id: fund_name
                size_hint: (1,0.1)
            Label:
                id: totaol_profit
                size_hint: (1,0.1)
        


